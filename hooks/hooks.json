{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/AGENTS.md\"",
            "commandWindows": "type \"%CLAUDE_PLUGIN_ROOT%\\AGENTS.md\"",
            "timeout": 5,
            "statusMessage": "Loading kittens-crew..."
          }
        ]
      }
    ]
  }
}
