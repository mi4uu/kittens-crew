# Copy to .env. The SAME auth, reused across every arm — passed as env into each
# container, so the mounted ~/.claude stays a clean, history-free config dir.
# Just paste the export lines from your provider script (claudeoneprovider.sh /
# claudeopenrouter.sh) here, WITHOUT the `export ` prefix. e.g.:

ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
# OpenRouter-style routing (optional — only if your provider uses it):
# OPENROUTER_API_KEY=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
